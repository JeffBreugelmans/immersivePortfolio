# Copy to .env.local -- defaults to the real Cloudflare Worker already used
# by chat-block.html on jeffxr.com. Only override this if you stand up a
# separate Worker/route for the WebXR app.
VITE_PROXIE_ENDPOINT=https://jeff-avatar-proxy.jeff-d02.workers.dev/

# scripts/marble-generate.mjs reads this (via dotenv) to call the World
# API. Get your key at https://platform.worldlabs.ai/api-keys -- never
# commit the real value, .env.local is gitignored for exactly this.
MARBLE_API_KEY=

# scripts/tripo-generate.mjs reads this (via dotenv) to call the Tripo
# API. Get your key at https://platform.tripo3d.ai/api-keys -- same
# gitignore protection as MARBLE_API_KEY above.
TRIPO3D_API_KEY=
