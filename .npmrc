# @sparkjsdev/spark#v2.0.0-preview declares peer three@^0.180.0, but this
# project (like the sensai-webxr-worldmodels template it follows) pins
# three -> super-three@0.181.0 for SparkJS 2.0 + IWSDK compatibility.
# npm's strict peer resolution rejects that pairing; the template's own
# lockfile was produced with legacy resolution, so mirror it here.
legacy-peer-deps=true
